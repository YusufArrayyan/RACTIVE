generator client {
  provider      = "prisma-client"
  output        = "../node_modules/@prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================
// AUTH MODELS
// ==============================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Creator profile
  niche         String?   @default("AI & Technology")
  platforms     String?   @default("YouTube,TikTok,Instagram") // comma-separated
  country       String?   @default("Global")
  contentStyle  String?   @default("Fast & Energetic")
  uploadTarget  String?   @default("3 videos/week")
  subscriberGoal String?  @default("100K by Dec 2025")
  revenueGoal   String?   @default("$10,000/month")
  targetAudience String?  @default("Creators 18-35, global")
  theme         String?   @default("system") // "light" | "dark" | "system"

  accounts      Account[]
  sessions      Session[]
  contentItems  ContentItem[]
  brainNotes    BrainNote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==============================
// CONTENT MODELS
// ==============================

model ContentItem {
  id             String   @id @default(cuid())
  userId         String
  title          String
  description    String?
  platform       String   @default("YouTube")
  niche          String?
  status         String   @default("Idea")
  viralScore     Int      @default(0)
  aiPriority     String   @default("Medium")
  scheduledDate  String?
  estimatedViews Int      @default(0)
  script         String?
  hook           String?
  hashtags       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrainNote {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String?
  category  String   @default("Ideas")
  color     String   @default("#8B5CF6")
  icon      String   @default("💡")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
